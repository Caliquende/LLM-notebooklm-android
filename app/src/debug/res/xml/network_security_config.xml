<?xml version="1.0" encoding="utf-8"?>
<!-- BUG-001 fix: localhost cleartext HTTP izni (10.0.2.2 = Android emulator host)
     Sadece debug build'de etkin; release build bu izni devralmamalı -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator → host 127.0.0.1 -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Fiziksel cihaz testi için kullanıcının ayarladığı custom bridge IP -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
